{
  "name": "emitfy/sdk",
  "description": "Official Emitfy API SDK for PHP (OpenAPI-typed)",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.1",
    "ext-json": "*",
    "ext-curl": "*",
    "guzzlehttp/guzzle": "^7.8"
  },
  "autoload": {
    "psr-4": {
      "Emitfy\\": "src/",
      "Emitfy\\Generated\\": "generated/lib/"
    }
  },
  "keywords": [
    "emitfy",
    "nfe",
    "nfse",
    "fiscal",
    "brazil",
    "sdk",
    "openapi"
  ],
  "homepage": "https://api.emitfy.com/docs/sdks",
  "support": {
    "docs": "https://api.emitfy.com/docs",
    "source": "https://github.com/emitfy/emitfy-php"
  }
}
